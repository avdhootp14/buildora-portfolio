# Production Environment Variables

# The port your server runs on (typically injected by your hosting provider like Heroku, Vercel, or Render)
PORT=5000

# Your production MongoDB connection string (e.g., from MongoDB Atlas)
# Do NOT use the local 127.0.0.1 URI in production!
# Format: mongodb+srv://<username>:<password>@cluster0.mongodb.net/buildora-portfolio?retryWrites=true&w=majority
MONGODB_URI=your_production_mongodb_connection_string_here

# A strong, randomly generated string used to sign your authentication tokens.
# Do NOT use a simple word. You can generate a strong key by running `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"` in your terminal.
JWT_SECRET=your_super_secret_and_long_random_string_here

# (Optional) If your frontend and backend are hosted on different domains in production, 
# you might want to specify the allowed origin for CORS to secure your API.
# ALLOWED_ORIGIN=https://www.yourdomain.com

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME="Buildora Admin"
SMTP_FROM=your_email@gmail.com
